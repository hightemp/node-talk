<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>     <string>en</string>
    <key>CFBundleDisplayName</key>           <string>NodeTalk</string>
    <key>CFBundleExecutable</key>            <string>NodeTalk</string>
    <key>CFBundleIconFile</key>              <string>nodetalk.icns</string>
    <key>CFBundleIdentifier</key>            <string>org.nodetalk.NodeTalk</string>
    <key>CFBundleInfoDictionaryVersion</key> <string>6.0</string>
    <key>CFBundleName</key>                  <string>NodeTalk</string>
    <key>CFBundlePackageType</key>           <string>APPL</string>
    <key>CFBundleShortVersionString</key>    <string>@PROJECT_VERSION@</string>
    <key>CFBundleVersion</key>               <string>@PROJECT_VERSION@</string>
    <key>LSMinimumSystemVersion</key>        <string>11.0</string>
    <key>NSHighResolutionCapable</key>       <true/>
    <key>NSHumanReadableCopyright</key>      <string>MIT License</string>
    <key>NSLocalNetworkUsageDescription</key>
    <string>NodeTalk discovers other NodeTalk users on your local network.</string>
    <key>NSBonjourServices</key>
    <array>
        <string>_nodetalk._udp</string>
    </array>
</dict>
</plist>
